{
  "name": "react-d3-viz",
  "version": "1.2.2",
  "description": "16 cross-platform SVG charts for React & React Native: LineChart, AreaChart, BarChart, ScatterPlot, BubbleChart, PieChart, QuadrantChart, Histogram, RadarChart, TreemapChart, SunburstChart, HeatmapChart, WaterfallChart, SankeyDiagram, MekkoChart, ButterflyChart. Composable, themeable, with tooltips, legends, animations.",
  "license": "MIT",
  "author": "www.kirandev.in",
  "homepage": "https://kiranb555.github.io/react-d3-viz-ui/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kiranb555/react-d3-viz.git"
  },
  "bugs": {
    "url": "https://github.com/kiranb555/react-d3-viz/issues"
  },
  "keywords": [
    "react",
    "react-native",
    "charts",
    "chart",
    "charts-library",
    "react-charts",
    "react-native-charts",
    "data-visualization",
    "dataviz",
    "visualization",
    "svg",
    "d3",
    "d3-shape",
    "graph",
    "line-chart",
    "bar-chart",
    "area-chart",
    "pie-chart",
    "donut-chart",
    "scatter-plot",
    "bubble-chart",
    "radar-chart",
    "histogram",
    "treemap",
    "sunburst",
    "heatmap",
    "waterfall",
    "sankey",
    "mekko",
    "butterfly",
    "quadrant",
    "cross-platform",
    "typescript",
    "composable",
    "themeable",
    "tooltips",
    "legend"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "react-native": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.lib.json",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "shots": "node scripts/shots.mjs"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/react-vite": "^10.3.6",
    "@testing-library/react": "^16.1.0",
    "@types/d3-array": "^3.2.2",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^25.0.1",
    "puppeteer-core": "^25.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-native-svg": "^15.0.0",
    "storybook": "^10.3.6",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^2.1.8"
  }
}
